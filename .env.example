# ─────────────────────────────────────────────────────────────────
#  Snowflake Summit — Postcard Activation
#  .env.example  →  copy to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────────

# Your Snowflake account identifier (e.g.  myorg-myaccount  or  xy12345.us-east-1)
SF_ACCOUNT=your_account_identifier

# Snowflake login
SF_USER=your_username
SF_PASSWORD=your_password

# Role that has access to SUMMIT_APP database AND the ZIP_CODES_DB marketplace dataset
SF_ROLE=SYSADMIN

# Warehouse created by init_db.sql
SF_WAREHOUSE=POSTCARD_WH
